{
  "name": "agent-debug-hub",
  "version": "1.0.0",
  "description": "Agent Debug Hub for monitoring and managing AI agents and LLM requests",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/server.js",
    "dev": "tsc && node dist/server.js",
